# Self-hosted fx-trader-profiles runtime settings.
# Copy this file to .env at the repository root before running docker compose.

# Public app URL used by the cron container and monitoring script.
APP_URL=http://web:3000
PUBLIC_APP_URL=http://localhost:3000

# Local image tag used by docker compose. No registry/GHCR is required for Phase A.
APP_IMAGE=fx-trader-profiles-web:local

# Postgres
POSTGRES_USER=fx_trader_profiles
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_DB=fx_trader_profiles
DATABASE_URL=postgresql://fx_trader_profiles:change-me-long-random-password@postgres:5432/fx_trader_profiles

# Hosted indexer
GOLDSKY_SUBGRAPH_URL=
GOLDSKY_API_KEY=
THE_GRAPH_SUBGRAPH_URL=

# RPC fallback, server-side only
GOLDSKY_RPC_URL=
CHAINSTACK_RPC_URL=
ALCHEMY_RPC_URL=
ETHEREUM_RPC_URL=https://rpc.flashbots.net
ETHEREUM_RPC_FALLBACK_URLS=https://ethereum-rpc.publicnode.com

# Optional ABI/contract-discovery helper
ETHERSCAN_API_KEY=

# Optional external seed/comparison sources
FX_LEADERBOARD_API_URL=
SMARTCLAW_BASE_URL=https://alidashboard.up.railway.app
SMARTCLAW_SITE_URL=https://smartclaw.xyz

# Job protection. The setup script can generate this if left blank.
CRON_SECRET=

# App config
NEXT_PUBLIC_APP_NAME=fx-trader-profiles
NEXT_PUBLIC_DEFAULT_CHAIN_ID=1

# HTTP exposure. Bind to 127.0.0.1 if using Caddy/Nginx on the host.
WEB_BIND_HOST=127.0.0.1
WEB_PORT=3000

# Watchtower
WATCHTOWER_POLL_INTERVAL=86400
WATCHTOWER_CLEANUP=true
WATCHTOWER_INCLUDE_RESTARTING=true
WATCHTOWER_LABEL_ENABLE=true

# Backups
POSTGRES_BACKUP_SCHEDULE=@daily
POSTGRES_BACKUP_KEEP_DAYS=7
POSTGRES_BACKUP_KEEP_WEEKS=4
POSTGRES_BACKUP_KEEP_MONTHS=3
